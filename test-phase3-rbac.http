### Restaurant OS Backend - Phase 3 RBAC Testing
### Use with REST Client extension in VS Code

@baseUrl = http://localhost:3000/api
@ownerToken = YOUR_OWNER_TOKEN_HERE
@managerToken = YOUR_MANAGER_TOKEN_HERE
@kitchenToken = YOUR_KITCHEN_TOKEN_HERE
@waiterToken = YOUR_WAITER_TOKEN_HERE

### ============================================
### SCENARIO 1: Owner Access (Full Access)
### ============================================

### 1.1 Owner creates tenant (✅ Should succeed)
POST {{baseUrl}}/tenants
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "name": "New Restaurant",
  "is_active": true
}

### 1.2 Owner creates menu item (✅ Should succeed)
POST {{baseUrl}}/menu-items
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "name": "Burger",
  "price": 9.99,
  "category": "Main"
}

### 1.3 Owner updates order status (✅ Should succeed)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "status": "preparing"
}

### 1.4 Owner deletes tenant (✅ Should succeed)
DELETE {{baseUrl}}/tenants/TENANT_ID_HERE
Authorization: Bearer {{ownerToken}}

### ============================================
### SCENARIO 2: Manager Access (Management Only)
### ============================================

### 2.1 Manager creates menu item (✅ Should succeed)
POST {{baseUrl}}/menu-items
Authorization: Bearer {{managerToken}}
Content-Type: application/json

{
  "name": "Salad",
  "price": 7.99,
  "category": "Appetizer"
}

### 2.2 Manager views tenants (✅ Should succeed)
GET {{baseUrl}}/tenants
Authorization: Bearer {{managerToken}}

### 2.3 Manager tries to delete tenant (❌ Should fail - 403)
DELETE {{baseUrl}}/tenants/TENANT_ID_HERE
Authorization: Bearer {{managerToken}}

### 2.4 Manager updates order status (✅ Should succeed)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{managerToken}}
Content-Type: application/json

{
  "status": "ready"
}

### 2.5 Manager creates profile (✅ Should succeed)
POST {{baseUrl}}/profiles
Authorization: Bearer {{managerToken}}
Content-Type: application/json

{
  "user_id": "USER_ID_HERE",
  "first_name": "John",
  "last_name": "Doe"
}

### ============================================
### SCENARIO 3: Kitchen Access (Status Updates Only)
### ============================================

### 3.1 Kitchen views orders (✅ Should succeed)
GET {{baseUrl}}/orders
Authorization: Bearer {{kitchenToken}}

### 3.2 Kitchen updates order status (✅ Should succeed)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{kitchenToken}}
Content-Type: application/json

{
  "status": "preparing"
}

### 3.3 Kitchen tries to create menu item (❌ Should fail - 403)
POST {{baseUrl}}/menu-items
Authorization: Bearer {{kitchenToken}}
Content-Type: application/json

{
  "name": "Pizza",
  "price": 12.99
}

### 3.4 Kitchen tries to delete order (❌ Should fail - 403)
DELETE {{baseUrl}}/orders/ORDER_ID_HERE
Authorization: Bearer {{kitchenToken}}

### 3.5 Kitchen tries to update order details (❌ Should fail - 403)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE
Authorization: Bearer {{kitchenToken}}
Content-Type: application/json

{
  "notes": "Updated notes"
}

### ============================================
### SCENARIO 4: Waiter Access (Order Taking)
### ============================================

### 4.1 Waiter creates order (✅ Should succeed)
POST {{baseUrl}}/orders
Authorization: Bearer {{waiterToken}}
Content-Type: application/json

{
  "table_number": "B3",
  "items": [
    {
      "menu_item_id": "MENU_ITEM_ID_HERE",
      "quantity": 2
    }
  ],
  "notes": "No onions"
}

### 4.2 Waiter views menu items (✅ Should succeed)
GET {{baseUrl}}/menu-items
Authorization: Bearer {{waiterToken}}

### 4.3 Waiter views orders (✅ Should succeed)
GET {{baseUrl}}/orders
Authorization: Bearer {{waiterToken}}

### 4.4 Waiter tries to create menu item (❌ Should fail - 403)
POST {{baseUrl}}/menu-items
Authorization: Bearer {{waiterToken}}
Content-Type: application/json

{
  "name": "Pasta",
  "price": 11.99
}

### 4.5 Waiter tries to update order status (❌ Should fail - 403)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{waiterToken}}
Content-Type: application/json

{
  "status": "ready"
}

### 4.6 Waiter tries to delete order (❌ Should fail - 403)
DELETE {{baseUrl}}/orders/ORDER_ID_HERE
Authorization: Bearer {{waiterToken}}

### ============================================
### SCENARIO 5: Order Status Transitions
### ============================================

### 5.1 Valid transition: pending → preparing (✅ Should succeed)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{kitchenToken}}
Content-Type: application/json

{
  "status": "preparing"
}

### 5.2 Valid transition: preparing → ready (✅ Should succeed)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{kitchenToken}}
Content-Type: application/json

{
  "status": "ready"
}

### 5.3 Valid transition: ready → delivered (✅ Should succeed)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{kitchenToken}}
Content-Type: application/json

{
  "status": "delivered"
}

### 5.4 Invalid transition: delivered → preparing (❌ Should fail - 400)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{kitchenToken}}
Content-Type: application/json

{
  "status": "preparing"
}

### 5.5 Valid transition: pending → cancelled (✅ Should succeed)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{managerToken}}
Content-Type: application/json

{
  "status": "cancelled"
}

### 5.6 Invalid transition: cancelled → preparing (❌ Should fail - 400)
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{kitchenToken}}
Content-Type: application/json

{
  "status": "preparing"
}

### ============================================
### SCENARIO 6: No Token (Unauthorized)
### ============================================

### 6.1 Try to access without token (❌ Should fail - 401)
GET {{baseUrl}}/orders

### 6.2 Try to create order without token (❌ Should fail - 401)
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "table_number": "A1",
  "items": []
}
